<Window x:Class="WpfApp2.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:WpfApp2.Views"
        mc:Ignorable="d"
        Title="ExifTool"
        Width="1280"
        Height="860"
        MinWidth="1080"
        MinHeight="760"
        WindowStartupLocation="CenterScreen"
        Background="#FFF6F7FB">
    <Window.Resources>
        <LinearGradientBrush x:Key="HeroBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FF1E274B" Offset="0" />
            <GradientStop Color="#FF323B72" Offset="0.55" />
            <GradientStop Color="#FF5462D7" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="PrimaryButtonBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FF5FA7FF" Offset="0" />
            <GradientStop Color="#FF2D7AF7" Offset="0.45" />
            <GradientStop Color="#FF2159DF" Offset="1" />
        </LinearGradientBrush>

        <DropShadowEffect x:Key="HeroShadow"
                          BlurRadius="28"
                          Direction="270"
                          ShadowDepth="8"
                          Opacity="0.22"
                          Color="#FF25315E" />

        <DropShadowEffect x:Key="CardShadow"
                          BlurRadius="24"
                          Direction="270"
                          ShadowDepth="6"
                          Opacity="0.18"
                          Color="#FF2C3155" />

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style TargetType="TabPanel">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,0,22" />
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="#F3F5FF" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="17" />
            <Setter Property="Margin" Value="6,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                MinWidth="120"
                                Padding="18,10"
                                Background="#1FFFFFFF"
                                BorderBrush="#4DB9CAFF"
                                BorderThickness="1"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource PrimaryButtonBrush}" />
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#80D8E7FF" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#99D8E7FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="#FFF6F7FB">
        <Border Margin="54,34,54,34"
                CornerRadius="24"
                Background="White"
                BorderBrush="#E7EBF5"
                BorderThickness="1"
                Effect="{StaticResource CardShadow}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="255" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Margin="32,28,32,0"
                        Padding="44,28,44,28"
                        CornerRadius="20"
                        Background="{StaticResource HeroBackgroundBrush}"
                        Effect="{StaticResource HeroShadow}">
                    <Grid>
                        <Ellipse Width="280"
                                 Height="280"
                                 HorizontalAlignment="Right"
                                 VerticalAlignment="Top"
                                 Margin="0,-120,-40,0"
                                 Fill="#22FFFFFF" />
                        <Ellipse Width="360"
                                 Height="360"
                                 HorizontalAlignment="Left"
                                 VerticalAlignment="Bottom"
                                 Margin="-160,0,0,-210"
                                 Fill="#155EC8FF" />

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock HorizontalAlignment="Center"
                                       FontSize="26"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       Text="Чтение и изменение метаданных изображений" />
                            <Border Height="1"
                                    Margin="0,18,0,0"
                                    Background="#25FFFFFF" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Margin="58,-78,58,32"
                        Padding="20"
                        CornerRadius="18"
                        Background="#FFFDFEFF"
                        BorderBrush="#EEF1F7"
                        BorderThickness="1"
                        Effect="{StaticResource CardShadow}">
                    <TabControl>
                        <TabItem Header="JPEG">
                            <views:ExtractView />
                        </TabItem>
                        <TabItem Header="PNG">
                            <views:EmbedView />
                        </TabItem>
                    </TabControl>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
