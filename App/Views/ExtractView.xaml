<UserControl x:Class="WpfApp2.Views.ExtractView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="620"
             d:DesignWidth="1040">
    <UserControl.Resources>
        <LinearGradientBrush x:Key="PrimaryButtonBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FF5FA7FF" Offset="0" />
            <GradientStop Color="#FF2D7AF7" Offset="0.45" />
            <GradientStop Color="#FF2159DF" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="18,12" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="{StaticResource PrimaryButtonBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardTextBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="14,12" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="BorderBrush" Value="#D7DEEE" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="22">
            <Grid Margin="0,0,0,22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="290" />
                </Grid.ColumnDefinitions>

                <StackPanel Margin="0,0,16,0">
                    <TextBlock Margin="0,0,0,10"
                               FontSize="16"
                               Foreground="#7C829D"
                               Text="Введите путь к изображению:" />
                    <TextBox Style="{StaticResource CardTextBoxStyle}"
                             Height="48"
                             VerticalContentAlignment="Center"
                             Text="Введите путь к изображению..." />
                </StackPanel>

                <Button Grid.Column="1"
                        Margin="0,30,0,0"
                        Height="48"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Content="Прикрепить файл" />
            </Grid>

            <Grid Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Margin="0,0,14,0"
                        Padding="18"
                        Background="#FF27304F"
                        CornerRadius="12"
                        BorderBrush="#33406A"
                        BorderThickness="1">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top"
                                   Margin="0,0,0,14"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   Text="Найденные данные" />
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <TextBlock Foreground="#F3F5FF"
                                       FontSize="15"
                                       LineHeight="30"
                                       Text="Формат: JPEG&#x0a;Автор: Demo User&#x0a;Описание: тестовая карточка просмотра&#x0a;Комментарий: здесь будет извлечённый текст&#x0a;Ключевое слово: hidden-metadata" />
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <Border Grid.Column="1"
                        Margin="14,0,0,0"
                        Padding="18"
                        Background="White"
                        CornerRadius="12"
                        BorderBrush="#DCE2F0"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Margin="0,0,0,14"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#FF2B3151"
                                   Text="Извлечённый текст" />
                        <TextBox MinHeight="182"
                                 AcceptsReturn="True"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Style="{StaticResource CardTextBoxStyle}"
                                 Text="Тут будет отображаться сообщение, извлечённое из метаданных изображения." />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Margin="0,0,0,18"
                    Height="1"
                    Background="#E8ECF5" />

            <Button Width="390"
                    Height="50"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,22"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Content="Извлечь метаданные" />

            <Border Padding="24"
                    Background="#FFF8FAFF"
                    BorderBrush="#D9DFEC"
                    BorderThickness="1"
                    CornerRadius="16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="400" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Margin="0,0,24,0"
                            Height="170"
                            CornerRadius="14"
                            BorderBrush="#D4DBED"
                            BorderThickness="1">
                        <Grid>
                            <Rectangle RadiusX="14"
                                       RadiusY="14">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#FFE7EDFF" Offset="0" />
                                        <GradientStop Color="#FFD2DCFF" Offset="0.45" />
                                        <GradientStop Color="#FFA3C3FF" Offset="1" />
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <Border Width="88"
                                        Height="88"
                                        Background="#55FFFFFF"
                                        CornerRadius="20"
                                        BorderBrush="#AAFFFFFF"
                                        BorderThickness="1">
                                    <Viewbox Margin="18">
                                        <TextBlock Text="JPEG" />
                                    </Viewbox>
                                </Border>
                                <TextBlock Margin="0,10,0,0"
                                           HorizontalAlignment="Center"
                                           FontSize="16"
                                           Foreground="#FF24406F"
                                           Text="Зона загрузки для анализа" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center">
                        <TextBlock HorizontalAlignment="Center"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="#FF2D3355"
                                   Text="Перетащите изображение сюда" />
                        <TextBlock Margin="0,6,0,14"
                                   HorizontalAlignment="Center"
                                   FontSize="18"
                                   Foreground="#8A90A9"
                                   Text="или" />
                        <Button Width="320"
                                Height="48"
                                HorizontalAlignment="Center"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Content="Выберите файл для проверки" />
                    </StackPanel>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
